{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user account information and subscription status.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique ID of the user." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "displayName": { "type": "string", "description": "The user's display name." },
        "photoURL": { "type": "string", "format": "uri", "description": "The user's profile photo URL." },
        "subscriptionStatus": { "type": "string", "enum": ["free", "premium"], "description": "The user's subscription status." },
        "whatsappNumber": { "type": "string", "description": "The user's WhatsApp number." },
        "taxRate": { "type": "number", "description": "The user's default tax rate." },
        "role": { "type": "string", "enum": ["shop_owner", "admin"], "description": "The user's role." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user account was created." },
        "notificationsEnabled": { "type": "boolean", "description": "Whether notifications are enabled." }
      },
      "required": ["uid", "email", "displayName", "subscriptionStatus", "role", "createdAt"]
    },
    "Product": {
      "title": "Product",
      "description": "Stores product information in the inventory.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the product." },
        "category": { "type": "string", "description": "The category of the product." },
        "size": { "type": "string", "description": "The size of the product." },
        "color": { "type": "string", "description": "The color of the product." },
        "material": { "type": "string", "description": "The material of the product." },
        "supplier": { "type": "string", "description": "The supplier of the product." },
        "imageUrl": { "type": "string", "format": "uri", "description": "The product's image URL." },
        "quantity": { "type": "number", "description": "The current quantity in stock." },
        "price": { "type": "number", "description": "The selling price of the product." },
        "costPrice": { "type": "number", "description": "The cost price of the product." },
        "discountPrice": { "type": "number", "description": "The discounted price of the product." },
        "taxRate": { "type": "number", "description": "The tax rate for this product." },
        "ownerId": { "type": "string", "description": "The UID of the user who owns this product." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the product was added." },
        "lastSoldAt": { "type": "string", "format": "date-time", "description": "When the product was last sold." }
      },
      "required": ["name", "category", "size", "quantity", "price", "costPrice", "ownerId", "createdAt"]
    },
    "Sale": {
      "title": "Sale",
      "description": "Stores information about a sale transaction.",
      "type": "object",
      "properties": {
        "productId": { "type": "string", "description": "The ID of the product sold." },
        "productName": { "type": "string", "description": "The name of the product sold." },
        "quantitySold": { "type": "number", "description": "The quantity of the product sold." },
        "soldAt": { "type": "string", "format": "date-time", "description": "When the sale occurred." },
        "ownerId": { "type": "string", "description": "The UID of the user who made the sale." },
        "totalAmount": { "type": "number", "description": "The total amount of the sale." },
        "costPrice": { "type": "number", "description": "The cost price of the product at the time of sale." },
        "subtotal": { "type": "number", "description": "The subtotal of the sale." },
        "taxAmount": { "type": "number", "description": "The tax amount of the sale." },
        "taxRate": { "type": "number", "description": "The tax rate applied to the sale." },
        "basePrice": { "type": "number", "description": "The base price of the product at the time of sale." }
      },
      "required": ["productId", "productName", "quantitySold", "soldAt", "ownerId", "totalAmount", "costPrice"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile documents."
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Product documents in the inventory."
    },
    "/sales/{saleId}": {
      "schema": "Sale",
      "description": "Sale transaction documents."
    }
  }
}
